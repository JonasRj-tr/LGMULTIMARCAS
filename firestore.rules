rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (Pillar 1 - Catch All Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Products Collection
    match /products/{productId} {
      allow read: if true;
      allow write: if true; // Allows unauthenticated seeding and inventory stock decrements on checkout
    }

    // Coupons Collection
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if true; // Allows unauthenticated seeding and admin coupon editing
    }

    // Settings Collection (Single Store Document)
    match /settings/{settingId} {
      allow read: if true;
      allow write: if true; // Allows unauthenticated seeding and admin store configuration edits
    }

    // Orders Transactions Log
    match /orders/{orderId} {
      allow read: if request.auth != null; // Only authenticated backoffice admins can view client orders
      allow write: if true; // Anyone can place/create an order, and admins can update statuses
    }
  }
}
